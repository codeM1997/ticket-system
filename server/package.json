  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/express": "5.0.6",
    "@types/cors": "2.8.19",
    "@types/node": "26.1.0",
    "tsx": "4.23.0",
    "prisma": "7.8.0",
    "vitest": "4.1.9",
    "supertest": "7.2.2",
    "@types/supertest": "7.2.0",
    "fast-check": "4.8.0"
  }
